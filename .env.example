# ── Copy to .env and fill in values before running the bot ──────────────────

# LLM Provider: "ollama" | "gemini" | "claude"
LLM_PROVIDER=ollama

# Ollama (local, gratis)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# Google Gemini — tier GRATUITO en aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude — ~$0.05/dia, mejor razonamiento
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Web Search (Tavily) — gratis 1000 busquedas/mes en tavily.com
TAVILY_API_KEY=
WEB_SEARCH_ENABLED=true
WEB_SEARCH_MAX_RESULTS=5

# Polymarket Wallet — solo dirección pública (clave privada va en Keychain)
POLYMARKET_WALLET_ADDRESS=0x...

# macOS Keychain item that holds the trading private key
KEYCHAIN_SERVICE=polymarket_pk
KEYCHAIN_ACCOUNT=bot_user

# Polygon RPC — comma-separated, tried in order
POLYGON_RPC_URLS=https://polygon-rpc.com,https://rpc-mainnet.matic.network,https://matic-mainnet.chainstacklabs.com

# Strategy tuning
KELLY_FRACTION=0.25          # 0.25 = 1/4 Kelly (conservative)
MAX_POSITION_USD=100.0       # hard cap per position
MIN_EV_THRESHOLD=0.03        # skip markets with EV < 3 %
MIN_CONFIDENCE=MEDIUM        # LOW | MEDIUM | HIGH

# Short-term pools (5-120 min crypto markets)
ENABLE_SHORT_TERM_MARKETS=true
SHORT_TERM_MAX_MINUTES=120
SHORT_TERM_MIN_LIQUIDITY_USD=500
SHORT_TERM_MIN_VOLUME_USD=100
SHORT_TERM_CYCLE_SECONDS=30
SHORT_TERM_MIN_EV_THRESHOLD=0.04
SHORT_TERM_USE_MONTE_CARLO=true
SHORT_TERM_MC_SAMPLES=2000
SHORT_TERM_MC_SEED=
SHORT_TERM_MC_EV_TOLERANCE=0.01
SHORT_TERM_MATH_MIN_CONFIDENCE=0.53
SHORT_TERM_MATH_MAX_CONFIDENCE=0.72
SHORT_TERM_MATH_MOMENTUM_WEIGHT=0.85
SHORT_TERM_MATH_OBI_WEIGHT=0.25
SHORT_TERM_MATH_VOL_PENALTY=0.15

# Exit strategy
TAKE_PROFIT_PCT=0.15
STOP_LOSS_PCT=0.10
EXIT_DAYS_BEFORE_END=1.0

# Market-making (spread capture) — OFF by default (risky without HFT infra)
MM_ENABLED=false
SPREAD_TARGET=0.02
MAX_MM_MARKETS=5
MM_CYCLE_SECONDS=10
MM_ORDER_SIZE_USD=25.0
MAX_CONSECUTIVE_LOSSES=3
MIN_BOOK_DEPTH_USD=500
OBI_BLOCK_THRESHOLD=-0.3
MAX_EFFECTIVE_SPREAD=0.10
TOXICITY_LOOKBACK=5

# Bot cadence
CYCLE_INTERVAL_SECONDS=300   # 5-minute evaluation loop
MAX_OPEN_POSITIONS=10

# Dry-run mode — true = evalúa sin gastar dinero
DRY_RUN=true
